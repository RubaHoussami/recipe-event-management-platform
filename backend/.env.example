DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/app
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_MINUTES=10080
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app
# Optional: 32-byte key for encrypting user OpenAI keys at rest. If unset, derived from JWT_SECRET.
# ENCRYPTION_KEY=

# Email (OTP verification). If SMTP_HOST is unset, OTP is logged but not sent (for local dev).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@yourdomain.com
# OTP_EXPIRE_MINUTES=15
# OTP_RESEND_COOLDOWN_SECONDS=60

# Hugging Face inference (hosted model). OpenAI-compatible API. Verified users can choose "Use hosted model".
# HF_API_KEY=your-hf-token
# HF_BASE_URL=https://router.huggingface.co/v1
# HF_MODEL=katanemo/Arch-Router-1.5B:hf-inference

# AI rate limit: max requests per user per minute (for AI parse/assign/suggest).
# AI_RATE_LIMIT_PER_MINUTE=30
